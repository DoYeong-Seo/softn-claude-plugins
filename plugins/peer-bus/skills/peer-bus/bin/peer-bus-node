#!/usr/bin/env bash
# peer-bus-node — Claude Code 가 .mcp.json 에서 실행하는 진입점 (mac / linux / WSL2 공통)
#
# 하는 일:
#   1) 로컬 공유 토큰 확보 (~/.peer-bus/token, 없으면 생성, 권한 600)
#   2) 허브가 떠 있는지 확인 → 죽어 있으면 detached 로 기동 (이 프로세스가 죽어도 허브는 생존)
#   3) bun 으로 peer-bus-node.ts 실행 (stdio MCP 서버)
#
# 허브 기동은 포트(:8900) 바인딩이 mutex 역할 — 두 세션이 동시에 띄워도 진 쪽은 EADDRINUSE 로 즉시 종료.
# WSL2: 백엔드·프론트 CC 세션과 이 스크립트가 모두 같은 distro 안에서 돌아야 localhost 가 일치한다.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PEER_BUS_HOME="${PEER_BUS_HOME:-$HOME/.peer-bus}"
HUB_PORT="${HUB_PORT:-8900}"
HUB_TS="$HERE/peer-bus-hub.ts"
NODE_TS="$HERE/peer-bus-node.ts"
LOG="$PEER_BUS_HOME/hub.log"

mkdir -p "$PEER_BUS_HOME"

# 1) 토큰: 환경변수 우선 → 없으면 파일 → 파일도 없으면 생성
if [ -z "${BUS_TOKEN:-}" ]; then
  if [ ! -s "$PEER_BUS_HOME/token" ]; then
    ( umask 077; openssl rand -hex 32 > "$PEER_BUS_HOME/token" )
  fi
  BUS_TOKEN="$(cat "$PEER_BUS_HOME/token")"
fi
export BUS_TOKEN HUB_PORT PEER_BUS_HOME
export HUB="${HUB:-http://127.0.0.1:${HUB_PORT}}"

probe() { curl -fsS -m 2 -H "X-Bus-Token: $BUS_TOKEN" "http://127.0.0.1:${HUB_PORT}/peers" >/dev/null 2>&1; }

# 2) 허브 보장 — 떠 있으면 그대로, 아니면 detached 기동 후 준비될 때까지 대기
if ! probe; then
  # ( ... & ) 서브셸 + nohup: 부모(이 스크립트/CC 세션)가 죽어도 허브는 init 에 reparent 되어 생존
  ( nohup bun "$HUB_TS" >>"$LOG" 2>&1 & ) || true
  for _ in $(seq 1 50); do
    probe && break
    sleep 0.1
  done
  probe || echo "[peer-bus-node] 경고: 허브 기동 실패 ($LOG 확인). 노드는 계속 진행." >&2
fi

# 3) stdio MCP 노드 실행 (NAME / PEER_BUS_MODE 는 .mcp.json env 에서 상속)
exec bun "$NODE_TS"
